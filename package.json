{
  "name": "twoteam",
  "private": true,
  "packageManager": "pnpm@10.2.0",
  "engines": {
    "node": "24.x"
  },
  "pnpm": {
    "overrides": {
      "minimatch@<4": "3.1.5",
      "minimatch@>=9.0.0 <9.0.7": "9.0.9",
      "rollup": ">=4.59.0",
      "vite": "6.4.2",
      "vitest": "3.0.5"
    }
  },
  "scripts": {
    "contracts:test": "node --test tests/contracts/*.test.mjs",
    "contracts:http:test": "node --test tests/contracts/http-differential.test.mjs",
    "upstream:analyze": "node scripts/analyze-upstream-update.mjs",
    "production:validate": "node scripts/validate-production-env.mjs",
    "production:load-smoke": "node scripts/load-smoke.mjs",
    "cutover:verify": "node scripts/verify-laravel-cutover.mjs",
    "cutover:smoke": "node scripts/smoke-laravel-cutover.mjs",
    "web:build": "corepack pnpm --filter @twoteam/web build",
    "web:chatwoot": "corepack pnpm --filter @twoteam/web build:chatwoot",
    "web:dev": "corepack pnpm --filter @twoteam/web dev",
    "web:test": "corepack pnpm --filter @twoteam/web test"
  }
}
