{
  "name": "@twoteam/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vue-tsc --noEmit && vite build",
    "build:chatwoot": "vite build --config vite.chatwoot.config.ts && bash ../../scripts/validate-chatwoot-build.sh",
    "dev": "vite --host 0.0.0.0",
    "test": "vitest run"
  },
  "dependencies": {
    "vue": "^3.5.12"
  },
  "devDependencies": {
    "@chatwoot/chatwoot": "workspace:*",
    "@rollup/plugin-yaml": "^4.1.2",
    "@types/node": "^22.7.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.20",
    "jsdom": "^27.0.0",
    "postcss-import": "15.1.0",
    "postcss-preset-env": "^8.5.1",
    "sass": "1.79.3",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.7.3",
    "vite": "6.4.2",
    "vitest": "3.0.5",
    "vue-tsc": "^2.2.0"
  }
}
