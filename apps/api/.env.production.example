APP_NAME=Twoteam
APP_ENV=production
APP_KEY=replace-with-php-artisan-key-generate-show
APP_DEBUG=false
APP_URL=https://support.example.com

LOG_CHANNEL=stderr
LOG_LEVEL=info
API_RATE_LIMIT_PER_MINUTE=300

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=twoteam
DB_USERNAME=twoteam
DB_PASSWORD=replace-with-strong-database-password

REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=replace-with-strong-redis-password
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_SECURE_COOKIE=true

FILESYSTEM_DISK=s3
MAIL_MAILER=smtp
