{
  "schemaVersion": 1,
  "minimumLaravelRoutes": 131,
  "requiredControllers": [
    "AccountController",
    "AgentController",
    "AssignmentController",
    "AttachmentController",
    "AuthSessionController",
    "AutomationRuleController",
    "CannedResponseController",
    "ContactController",
    "ConversationController",
    "ConversationLabelController",
    "CsatSurveyController",
    "FrontendController",
    "HealthController",
    "HelpCenterArticleController",
    "HelpCenterCategoryController",
    "InboundEmailController",
    "InboxController",
    "LabelController",
    "MacroController",
    "MessageController",
    "MetaWebhookController",
    "NotificationController",
    "NotificationSettingController",
    "PortalController",
    "PrioritizedWebhookController",
    "PublicHelpCenterController",
    "RealtimeController",
    "ReportController",
    "SearchController",
    "TeamController",
    "WebhookSubscriptionController",
    "WhatsappWebhookController",
    "WidgetController"
  ],
  "requiredRoutes": [
    { "method": "GET", "uri": "app/{path?}", "controller": "FrontendController" },
    { "method": "POST", "uri": "auth/sign_in", "controller": "AuthSessionController" },
    { "method": "GET", "uri": "api/v1/accounts/{account}/conversations", "controller": "ConversationController" },
    { "method": "POST", "uri": "api/v1/accounts/{account}/conversations/{conversation}/messages", "controller": "MessageController" },
    { "method": "POST", "uri": "api/v1/widget/conversations", "controller": "WidgetController" },
    { "method": "GET", "uri": "api/v2/accounts/{account}/reports", "controller": "ReportController" },
    { "method": "GET", "uri": "api/hc/{portal}/{locale}/articles.json", "controller": "PublicHelpCenterController" },
    { "method": "POST", "uri": "api/v1/email/inbound/{channel}", "controller": "InboundEmailController" },
    { "method": "POST", "uri": "api/v1/whatsapp/webhook/{channel}", "controller": "WhatsappWebhookController" },
    { "method": "POST", "uri": "api/v1/meta/webhook/{channel}", "controller": "MetaWebhookController" },
    { "method": "POST", "uri": "api/v1/channels/webhook/{channel}", "controller": "PrioritizedWebhookController" }
  ],
  "productionServices": [
    "api",
    "migrate",
    "postgres",
    "redis",
    "scheduler",
    "web",
    "worker"
  ]
}
